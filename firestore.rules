rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: students
    // Fields: name, goal, startDate, level, pattern, ownerId
    //
    // Collection: sessions
    // Fields: studentId, num, date, reaction, next, techniques, aiSummary, mode, ownerId
    //
    // Collection: configs
    // Fields: techniques, levels, ownerId
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.ownerId;
    }

    function isValidStudent(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.level is string &&
             data.ownerId == request.auth.uid;
    }

    function isValidSession(data) {
      return data.studentId is string &&
             data.num is number &&
             data.date is string &&
             data.ownerId == request.auth.uid;
    }

    function isValidConfig(data) {
      return data.ownerId == request.auth.uid &&
             data.techniques is list &&
             data.levels is list;
    }

    // Rules
    match /students/{studentId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.ownerId == request.auth.uid);
      allow create: if isAuthenticated() && isValidStudent(request.resource.data);
      allow update: if isAuthenticated() && isDocOwner() && isValidStudent(request.resource.data);
      allow delete: if isAuthenticated() && isDocOwner();
    }

    match /sessions/{sessionId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.ownerId == request.auth.uid);
      allow create: if isAuthenticated() && isValidSession(request.resource.data);
      allow update: if isAuthenticated() && isDocOwner() && isValidSession(request.resource.data);
      allow delete: if isAuthenticated() && isDocOwner();
    }

    match /configs/{configId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.ownerId == request.auth.uid);
      allow write: if isAuthenticated() && (resource == null || resource.data.ownerId == request.auth.uid) && isValidConfig(request.resource.data);
    }
  }
}
